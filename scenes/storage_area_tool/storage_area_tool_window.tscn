[node name="HSeparator" type="HSeparator" parent="VBoxContainer"]
layout_mode = 2

[node name="PlaceButton" type="Button" parent="VBoxContainer"]
layout_mode = 2
toggle_mode = true
text = "Place Storage Area"

[node name="DeleteButton" type="Button" parent="VBoxContainer"]
layout_mode = 2
toggle_mode = true
text = "Delete Storage Area"
